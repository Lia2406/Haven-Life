-- TAMBAHAN: FARM PLOT SYSTEM
-- ══════════════════════════════════════
local FarmPlotSystem = require(Modules:WaitForChild("FarmPlotSystem"))

local farmSystem = FarmPlotSystem.new()
_G.farmSystemRef = farmSystem

-- Callback harvest → tambah ke inventory
farmSystem.onHarvest = function(player, cropId, amount)
	local inv = playerInventories[player.UserId]
	if inv then
		inv:addItem(cropId, amount)
		print(string.format("[Farm] %s panen %s x%d", player.Name, cropId, amount))
	end
end

-- Callback konsumsi bibit
farmSystem.onConsume = function(player, itemId, amount)
	local inv = playerInventories[player.UserId]
	if inv then
		inv:removeItem(itemId, amount)
		print(string.format("[Farm] %s pakai %s x%d", player.Name, itemId, amount))
	end
end

-- Callback notifikasi ke player
farmSystem.onNotify = function(player, message)
	local notifEv = remotes:FindFirstChild("ShowNotif")
	if notifEv then
		notifEv:FireClient(player, message)
	end
end

task.wait(2)
farmSystem:scanAndSetup()

