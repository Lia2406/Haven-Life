-- ══════════════════════════════════════
-- TAMBAHAN: SHIPPING BIN SYSTEM
-- ══════════════════════════════════════
local ShippingBinSystem = require(Modules:WaitForChild("ShippingBinSystem"))

local shippingBin = ShippingBinSystem.new()

-- ── REMOTE EVENTS UNTUK SHIPPING BIN ──
local binRemotes = Instance.new("Folder")
binRemotes.Name   = "ShippingBinRemotes"
binRemotes.Parent = remotes

local OpenBinUI    = Instance.new("RemoteEvent")
OpenBinUI.Name      = "OpenBinUI"
OpenBinUI.Parent    = binRemotes

local RequestSell  = Instance.new("RemoteEvent")
RequestSell.Name    = "RequestSell"
RequestSell.Parent  = binRemotes

-- ── SAAT BIN DIBUKA: KIRIM ISI INVENTORY YANG BISA DIJUAL ──
shippingBin.onOpen = function(player)
	local inv = playerInventories[player.UserId]
	if not inv then return end

	local snapshot = inv:getSnapshot()

	-- Filter hanya item yang punya sellPrice (hasil panen, bukan tool/seed)
	local sellableItems = {}
	for i, slot in pairs(snapshot.slots) do
		if slot then
			local data = ItemData.get(slot.itemId)
			if data and data.sellPrice then
				table.insert(sellableItems, {
					slotIndex = i,
					itemId    = slot.itemId,
					name      = data.name,
					count     = slot.count,
					sellPrice = data.sellPrice,
				})
			end
		end
	end

	OpenBinUI:FireClient(player, sellableItems)
end

-- ── HANDLE REQUEST JUAL DARI CLIENT ──
RequestSell.OnServerEvent:Connect(function(player, slotIndex, sellAmount)
	local inv      = playerInventories[player.UserId]
	local currency = playerCurrencies[player.UserId]
	if not inv or not currency then return end

	local snapshot = inv:getSnapshot()
	local slot      = snapshot.slots[slotIndex]
	if not slot then return end

	local data = ItemData.get(slot.itemId)
	if not data or not data.sellPrice then return end

	sellAmount = math.min(sellAmount, slot.count)
	if sellAmount <= 0 then return end

	-- Hapus item dari inventory & tambah koin
	local success = inv:removeFromSlot(slotIndex, sellAmount)
	if success then
		local totalPrice = data.sellPrice * sellAmount
		currency:add(totalPrice)
		print(string.format("[ShippingBin] %s menjual %s x%d seharga %d koin",
			player.Name, data.name, sellAmount, totalPrice))
	end
end)

-- ── START SCAN BIN ──
task.wait(1)
shippingBin:scanAndSetup()

print("[ShippingBin System] Aktif.")

-- ══════════════════════════════════════
-- TAMBAHAN: SHOP SYSTEM
-- ══════════════════════════════════════
local ShopSystem = require(Modules:WaitForChild("ShopSystem"))

local shopSystem = ShopSystem.new()

-- Remote untuk toko
local shopRemotes = Instance.new("Folder")
shopRemotes.Name   = "ShopRemotes"
shopRemotes.Parent = remotes

local OpenShopUI  = Instance.new("RemoteEvent")
OpenShopUI.Name    = "OpenShopUI"
OpenShopUI.Parent  = shopRemotes

local RequestBuy  = Instance.new("RemoteEvent")
RequestBuy.Name    = "RequestBuy"
RequestBuy.Parent  = shopRemotes

-- Saat toko dibuka — kirim katalog ke client
shopSystem.onOpen = function(player)
	-- Kumpulkan semua item yang bisa dibeli
	local catalog = {}
	for itemId, data in pairs(ItemData.Items) do
		if data.buyPrice then
			table.insert(catalog, {
				itemId   = itemId,
				name     = data.name,
				icon     = data.icon,
				buyPrice = data.buyPrice,
				type     = data.type,
			})
		end
	end

	-- Urutkan: tool dulu, lalu seed
	table.sort(catalog, function(a, b)
		if a.type == b.type then return a.name < b.name end
		return a.type == "tool"
	end)

	OpenShopUI:FireClient(player, catalog)
end

-- Handle request beli dari client
RequestBuy.OnServerEvent:Connect(function(player, itemId, amount)
	print("=== REQUEST BUY DITERIMA:", player.Name, itemId, amount)  -- TAMBAH INI
	local inv      = playerInventories[player.UserId]
	local currency = playerCurrencies[player.UserId]
	print("=== INV:", inv, "| CURRENCY:", currency)  -- TAMBAH INI
	
	if not inv or not currency then return end
	print("=== GAGAL: inv atau currency nil!")  -- TAMBAH INI

	local data = ItemData.get(itemId)
	if not data or not data.buyPrice then return end

	amount = math.max(1, math.floor(amount or 1))

	local totalCost = data.buyPrice * amount
	if not currency:hasEnough(totalCost) then
		-- Kirim notif tidak cukup koin
		local notifEv = remotes:FindFirstChild("ShowNotif")
		if notifEv then
			notifEv:FireClient(player, 
				string.format("Koin tidak cukup! Butuh %d koin.", totalCost))
		end
		return
	end

	-- Kurangi koin & tambah item
	currency:remove(totalCost)
	local success = inv:addItem(itemId, amount)

	if success then
		print(string.format("[Shop] %s membeli %s x%d seharga %d koin",
			player.Name, data.name, amount, totalCost))
	end
end)

task.wait(1)
shopSystem:scanAndSetup()

print("[Shop System] Aktif.")

