-- GameServer.lua
-- Entry point tunggal — instansiasi dan hubungkan semua sistem
-- Satu-satunya file yang "tahu" semua module
print("=== GAMESERVER MULAI DIEKSEKUSI ===")
local ReplicatedStorage = game:GetService("ReplicatedStorage")
local Lighting          = game:GetService("Lighting")

-- ── LOAD MODULES ──
local Modules    = ReplicatedStorage:WaitForChild("Modules")
local Calendar   = require(Modules:WaitForChild("Calendar"))
local TimeSystem = require(Modules:WaitForChild("TimeSystem"))
local BedSystem  = require(Modules:WaitForChild("BedSystem"))
local ItemData   = require(Modules:WaitForChild("ItemData")) 

-- ── SETUP REMOTE EVENTS ──
local remotes = Instance.new("Folder")
remotes.Name  = "GameRemotes"
remotes.Parent = ReplicatedStorage

local function makeRemote(name)
	local r = Instance.new("RemoteEvent")
	r.Name   = name
	r.Parent = remotes
	return r
end

local Remotes = {
	SleepFadeOut  = makeRemote("SleepFadeOut"),   -- server → client: layar gelap
	SleepFadeIn   = makeRemote("SleepFadeIn"),    -- server → client: bangun pagi
	CalendarSync  = makeRemote("CalendarSync"),   -- server → client: update HUD
	ShowNotif     = makeRemote("ShowNotif"),       -- server → client: notifikasi
}

-- ── INSTANSIASI ──
local calendar   = Calendar.new()
local timeSystem = TimeSystem.new()
local bedSystem  = BedSystem.new()

-- ── INISIALISASI LIGHTING ──
Lighting.ClockTime      = 6.0
Lighting.Brightness     = 2
Lighting.ShadowSoftness = 0.5

-- ── CALLBACK: HARI BERGANTI ──
-- Dipanggil oleh Calendar setiap kali advance()
calendar.onDayChanged = function(snap, source)
	-- Update season di TimeSystem
	timeSystem:setSeason(snap.seasonIndex)

	-- Broadcast ke semua client
	Remotes.CalendarSync:FireAllClients(snap)
	
	if rawget(_G, "farmSystemRef") then
		_G.farmSystemRef:advanceDay()
	end

	-- Notifikasi jika via tengah malam (bukan tidur)
	if source == "midnight" then
		Remotes.ShowNotif:FireAllClients(
			string.format("Hari %d — %s %s — Tahun %d",
				snap.day, snap.seasonIcon, snap.seasonName, snap.year),
			"midnight"
		)
	end
end

-- ── CALLBACK: TENGAH MALAM ──
timeSystem.onMidnight = function()
	calendar:advance("midnight")
end

-- ── CALLBACK: TIDUR DI KASUR ──
local sleepLock = false

bedSystem.onSleep = function(_bed)
	if sleepLock then return end
	sleepLock = true

	-- Kirim fadeOut ke client
	Remotes.SleepFadeOut:FireAllClients()

	-- Tunggu animasi gelap
	task.wait(1.5)

	-- Skip jam ke pagi
	timeSystem:skipToMorning()

	-- Advance hari
	local snap = calendar:advance("sleep")

	-- Kirim fadeIn + data hari baru ke client
	Remotes.SleepFadeIn:FireAllClients(snap)

	task.wait(3)
	sleepLock = false
end

-- ── START SEMUA SISTEM ──
task.wait(1)
bedSystem:scanAndSetup()
timeSystem:start()

-- Broadcast kalender awal ke client yang join
game:GetService("Players").PlayerAdded:Connect(function()
	task.wait(2)
	Remotes.CalendarSync:FireAllClients(calendar:getSnapshot())
end)

-- ══════════════════════════════════════
-- TAMBAHAN: INVENTORY SYSTEM
-- ══════════════════════════════════════
local InventoryManager = require(Modules:WaitForChild("InventoryManager"))
local Players           = game:GetService("Players")

-- Simpan inventory per player
local playerInventories = {}

-- ── REMOTE EVENTS UNTUK INVENTORY ──
local invRemotes = Instance.new("Folder")
invRemotes.Name   = "InventoryRemotes"
invRemotes.Parent = remotes  -- masuk ke folder GameRemotes yang sudah ada

local function makeInvRemote(name)
	local r = Instance.new("RemoteEvent")
	r.Name   = name
	r.Parent = invRemotes
	return r
end

local InvRemotes = {
	Sync         = makeInvRemote("InventorySync"),       -- server → client: update tampilan
	SelectSlot   = makeInvRemote("SelectSlot"),           -- client → server: ganti slot aktif
	MoveSlot     = makeInvRemote("MoveSlot"),             -- client → server: drag & drop
}

-- ── SETUP INVENTORY SAAT PLAYER JOIN ──
local function setupPlayerInventory(player)
	local inv = InventoryManager.new(player)
	playerInventories[player.UserId] = inv

	inv.onChanged = function(snapshot)
		InvRemotes.Sync:FireClient(player, snapshot)
	end

	-- Starter item (opsional, sesuaikan)
	inv:addItem("Hoe", 1)
	inv:addItem("WateringCan", 1)
	inv:addItem("WheatSeed", 5)

	-- Kirim snapshot awal
	InvRemotes.Sync:FireClient(player, inv:getSnapshot())

	print("[Inventory] Setup untuk:", player.Name)
end

Players.PlayerAdded:Connect(setupPlayerInventory)

-- Untuk player yang sudah join sebelum script ini jalan (testing di Studio)
for _, player in ipairs(Players:GetPlayers()) do
	setupPlayerInventory(player)
end

Players.PlayerRemoving:Connect(function(player)
	playerInventories[player.UserId] = nil
end)

-- ── HANDLE REQUEST DARI CLIENT ──
InvRemotes.SelectSlot.OnServerEvent:Connect(function(player, slotIndex)
	local inv = playerInventories[player.UserId]
	if inv then
		inv:selectSlot(slotIndex)
	end
end)

InvRemotes.MoveSlot.OnServerEvent:Connect(function(player, fromIndex, toIndex)
	local inv = playerInventories[player.UserId]
	if inv then
		inv:moveSlot(fromIndex, toIndex)
	end
end)

-- ── EXPOSE FUNGSI GLOBAL UNTUK SCRIPT LAIN (ShippingBin, CropSystem dll) ──
_G.GetPlayerInventory = function(player)
	return playerInventories[player.UserId]
end

print("[Inventory System] Aktif.")

