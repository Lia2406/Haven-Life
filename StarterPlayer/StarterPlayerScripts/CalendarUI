-- EVENT HANDLERS
-- ══════════════════════════════════════

-- Update HUD kalender
Remotes.CalendarSync.OnClientEvent:Connect(function(snap)
	seasonLabel.Text       = snap.seasonIcon .. "  " .. snap.seasonName
	seasonLabel.TextColor3 = snap.seasonColor
	dayLabel.Text          = string.format("Hari %d  ·  Tahun %d", snap.day, snap.year)
end)

-- Sync koin dari server
local currencyRemote = remotes:WaitForChild("CurrencySync")
currencyRemote.OnClientEvent:Connect(function(amount)
	coinLabel.Text = tostring(amount)
end)

-- Sync air dari server
local waterRemote = remotes:WaitForChild("WaterSync")
waterRemote.OnClientEvent:Connect(function(current, max)
	local lbl = waterFrame:FindFirstChild("WaterLabel")
	if lbl then
		lbl.Text = string.format("%d/%d", current, max)
		-- Merah kalau hampir habis
		lbl.TextColor3 = (current <= 1)
			and Color3.fromRGB(255, 100, 80)
			or  Color3.fromRGB(120, 200, 255)
	end
end)

-- Guard anti double trigger
local isSleeping = false

-- Fade to black (mulai tidur)
Remotes.SleepFadeOut.OnClientEvent:Connect(function()
	if isSleeping then return end
	isSleeping = true

	-- Reset paksa dulu biar bersih
	blackFrame.BackgroundTransparency = 1
	zzzLabel.TextTransparency         = 1
	newDayLabel.TextTransparency      = 1
	newDayLabel.Text                  = ""

	tw(blackFrame, 0.9, {BackgroundTransparency = 0})
	tw(zzzLabel,   0.9, {TextTransparency = 0})
end)

-- Fade from black (bangun pagi)
Remotes.SleepFadeIn.OnClientEvent:Connect(function(snap)
	if not isSleeping then return end  -- tolak kalau FadeOut belum jalan

	if snap then
		newDayLabel.Text = string.format(
			"%s  Hari %d  ·  %s  ·  Tahun %d",
			snap.seasonIcon, snap.day, snap.seasonName, snap.year
		)
	end

	-- Jalankan dalam coroutine agar tidak block event lain
	task.spawn(function()
		tw(newDayLabel, 0.5, {TextTransparency = 0})
		task.wait(2)

		tw(blackFrame,  1.2, {BackgroundTransparency = 1})
		tw(zzzLabel,    1.2, {TextTransparency = 1})
		tw(newDayLabel, 1.2, {TextTransparency = 1})

		task.wait(1.3)  -- tunggu tween fade-out selesai
		isSleeping = false  -- baru reset guard
	end)
end)

-- Notifikasi (tengah malam dll)
local notifBusy  = false
local notifQueue = {}

local function processNotifQueue()
	if notifBusy then return end
	notifBusy = true
	task.spawn(function()
		while #notifQueue > 0 do
			local msg = table.remove(notifQueue, 1)
			notifText.Text = msg
			tw(notifFrame, 0.35, {Position = UDim2.new(0.5, -170, 0, 14)})
			task.wait(1.5)
			tw(notifFrame, 0.35, {Position = UDim2.new(0.5, -170, 0, -60)})
			task.wait(0.5)
		end
		notifBusy = false
	end)
end

Remotes.ShowNotif.OnClientEvent:Connect(function(msg)
	table.insert(notifQueue, msg)
	processNotifQueue()
end)

