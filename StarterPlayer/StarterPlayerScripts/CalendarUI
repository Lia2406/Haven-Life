-- HELPER
-- ══════════════════════════════════════
local function tw(obj, t, props)
	TweenService:Create(obj,
		TweenInfo.new(t, Enum.EasingStyle.Quad, Enum.EasingDirection.InOut),
		props
	):Play()
end

