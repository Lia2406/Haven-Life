-- ══════════════════════════════════════
-- BUAT 1 BARIS ITEM YANG BISA DIJUAL
-- ══════════════════════════════════════
local function createItemRow(itemInfo)
	local row = Instance.new("Frame")
	row.Size                   = UDim2.new(1, -8, 0, 64)
	row.BackgroundColor3       = Color3.fromRGB(50, 36, 22)
	row.BorderSizePixel        = 0
	row.ZIndex                 = 42
	row.Parent                 = listFrame
	corner(row, 8)

	local nameLabel = Instance.new("TextLabel")
	nameLabel.Size                   = UDim2.new(0.4, 0, 0, 24)
	nameLabel.Position               = UDim2.new(0, 10, 0, 6)
	nameLabel.BackgroundTransparency = 1
	nameLabel.Text                   = itemInfo.name
	nameLabel.TextColor3             = Color3.fromRGB(255, 230, 180)
	nameLabel.TextSize               = 16
	nameLabel.Font                   = Enum.Font.GothamBold
	nameLabel.TextXAlignment         = Enum.TextXAlignment.Left
	nameLabel.ZIndex                 = 43
	nameLabel.Parent                 = row

	local infoLabel = Instance.new("TextLabel")
	infoLabel.Size                   = UDim2.new(0.4, 0, 0, 20)
	infoLabel.Position               = UDim2.new(0, 10, 0, 32)
	infoLabel.BackgroundTransparency = 1
	infoLabel.Text                   = string.format("Punya: %d  ·  %d koin/item", itemInfo.count, itemInfo.sellPrice)
	infoLabel.TextColor3             = Color3.fromRGB(190, 170, 140)
	infoLabel.TextSize               = 12
	infoLabel.Font                   = Enum.Font.Gotham
	infoLabel.TextXAlignment         = Enum.TextXAlignment.Left
	infoLabel.ZIndex                 = 43
	infoLabel.Parent                 = row

	-- ── INPUT JUMLAH ──
	local qtyBox = Instance.new("TextBox")
	qtyBox.Size                   = UDim2.new(0, 50, 0, 32)
	qtyBox.Position               = UDim2.new(1, -180, 0.5, -16)
	qtyBox.BackgroundColor3       = Color3.fromRGB(25, 18, 10)
	qtyBox.Text                   = tostring(itemInfo.count)
	qtyBox.TextColor3             = Color3.fromRGB(255, 255, 255)
	qtyBox.TextSize               = 14
	qtyBox.Font                   = Enum.Font.Gotham
	qtyBox.ClearTextOnFocus       = false
	qtyBox.ZIndex                 = 43
	qtyBox.Parent                 = row
	corner(qtyBox, 6)
	stroke(qtyBox, Color3.fromRGB(90, 65, 35), 1)

	-- ── TOMBOL MAX ──
	local maxBtn = Instance.new("TextButton")
	maxBtn.Size                   = UDim2.new(0, 44, 0, 32)
	maxBtn.Position               = UDim2.new(1, -124, 0.5, -16)
	maxBtn.BackgroundColor3       = Color3.fromRGB(70, 55, 30)
	maxBtn.Text                   = "Max"
	maxBtn.TextColor3             = Color3.fromRGB(255, 230, 180)
	maxBtn.TextSize               = 12
	maxBtn.Font                   = Enum.Font.GothamBold
	maxBtn.ZIndex                 = 43
	maxBtn.Parent                 = row
	corner(maxBtn, 6)

	maxBtn.MouseButton1Click:Connect(function()
		qtyBox.Text = tostring(itemInfo.count)
	end)

	-- ── TOMBOL JUAL ──
	local sellBtn = Instance.new("TextButton")
	sellBtn.Size                   = UDim2.new(0, 68, 0, 32)
	sellBtn.Position               = UDim2.new(1, -70, 0.5, -16)
	sellBtn.BackgroundColor3       = Color3.fromRGB(60, 130, 70)
	sellBtn.Text                   = "Jual"
	sellBtn.TextColor3             = Color3.fromRGB(255, 255, 255)
	sellBtn.TextSize               = 14
	sellBtn.Font                   = Enum.Font.GothamBold
	sellBtn.ZIndex                 = 43
	sellBtn.Parent                 = row
	corner(sellBtn, 6)

	sellBtn.MouseButton1Click:Connect(function()
		local qty = tonumber(qtyBox.Text)
		if qty and qty > 0 then
			RequestSell:FireServer(itemInfo.slotIndex, math.floor(qty))

			-- Feedback visual singkat
			sellBtn.Text = "✓"
			task.wait(0.3)
			-- Tutup panel & buka ulang untuk refresh data (sederhana tapi efektif)
			closePanel()
		end
	end)

	return row
end

-- ══════════════════════════════════════
-- BUKA / TUTUP PANEL
-- ══════════════════════════════════════
local isOpen = false

local function openPanel(sellableItems)
	if isOpen then return end
	isOpen = true

	-- Bersihkan list lama
	for _, child in ipairs(listFrame:GetChildren()) do
		if child:IsA("Frame") then
			child:Destroy()
		end
	end

	if #sellableItems == 0 then
		local emptyLabel = Instance.new("TextLabel")
		emptyLabel.Size                   = UDim2.new(1, 0, 0, 60)
		emptyLabel.BackgroundTransparency = 1
		emptyLabel.Text                   = "Tidak ada hasil panen untuk dijual"
		emptyLabel.TextColor3             = Color3.fromRGB(180, 160, 130)
		emptyLabel.TextSize               = 14
		emptyLabel.Font                   = Enum.Font.Gotham
		emptyLabel.ZIndex                 = 43
		emptyLabel.Parent                 = listFrame
	else
		for _, itemInfo in ipairs(sellableItems) do
			createItemRow(itemInfo)
		end
	end

	overlay.Visible = true
	panel.Visible   = true

	TweenService:Create(overlay, TweenInfo.new(0.25), {BackgroundTransparency = 0.5}):Play()

	panel.Position = UDim2.new(0.5, -210, 0.55, -230)
	TweenService:Create(panel, 
		TweenInfo.new(0.3, Enum.EasingStyle.Back, Enum.EasingDirection.Out),
		{Position = UDim2.new(0.5, -210, 0.5, -230)}
	):Play()
end

function closePanel()
	if not isOpen then return end
	isOpen = false

	TweenService:Create(overlay, TweenInfo.new(0.2), {BackgroundTransparency = 1}):Play()
	local t = TweenService:Create(panel, TweenInfo.new(0.2),
		{Position = UDim2.new(0.5, -210, 0.55, -230)}
	)
	t:Play()
	t.Completed:Wait()

	overlay.Visible = false
	panel.Visible   = false
end

closeBtn.MouseButton1Click:Connect(closePanel)
overlay.InputBegan:Connect(function(input)
	if input.UserInputType == Enum.UserInputType.MouseButton1 then
		closePanel()
	end
end)

-- ══════════════════════════════════════
-- TERIMA DATA DARI SERVER
-- ══════════════════════════════════════
OpenBinUI.OnClientEvent:Connect(function(sellableItems)
	openPanel(sellableItems)
end)

