-- ShippingBinUI.lua
-- Panel jual item: pilih item, pilih jumlah, konfirmasi jual

local Players           = game:GetService("Players")
local ReplicatedStorage = game:GetService("ReplicatedStorage")
local TweenService      = game:GetService("TweenService")

local player    = Players.LocalPlayer
local playerGui = player:WaitForChild("PlayerGui")

local remotes    = ReplicatedStorage:WaitForChild("GameRemotes")
local binRemotes = remotes:WaitForChild("ShippingBinRemotes")

local OpenBinUI   = binRemotes:WaitForChild("OpenBinUI")
local RequestSell = binRemotes:WaitForChild("RequestSell")

-- ══════════════════════════════════════
-- BUILD UI
-- ══════════════════════════════════════
local gui = Instance.new("ScreenGui")
gui.Name           = "ShippingBinUI"
gui.ResetOnSpawn   = false
gui.ZIndexBehavior = Enum.ZIndexBehavior.Sibling
gui.DisplayOrder   = 50
gui.Parent         = playerGui

local function corner(parent, r)
	local c = Instance.new("UICorner")
	c.CornerRadius = UDim.new(0, r or 8)
	c.Parent = parent
end

local function stroke(parent, color, thick)
	local s = Instance.new("UIStroke")
	s.Color     = color or Color3.fromRGB(120, 85, 45)
	s.Thickness = thick or 2
	s.Parent    = parent
end

